# Flask Settings
SECRET_KEY=retailflow-secret-key-change-me
JWT_SECRET_KEY=retailflow-jwt-secret-key-change-me
CORS_ORIGINS=*

# Database Connection (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=retailflow_user
MYSQL_PASSWORD=retailflow_password
MYSQL_DATABASE=retailflow_ai

# Optional DB Configuration Override
# DATABASE_URL=mysql+pymysql://retailflow_user:retailflow_password@localhost:3306/retailflow_ai

# SQLite Fallback (default for local testing)
SQLITE_DATABASE_URL=sqlite:///retailflow.db